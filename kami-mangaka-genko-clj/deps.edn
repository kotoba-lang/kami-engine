;; kami-mangaka-genko-clj — 原稿 (genko) manga-editor document model, cljc SSoT.
;;
;; genko-embed.ts（kami-engine-sdk の WebGPU pentab エディタ）が持っていた
;; document/page/node モデル + node-tree ops + oplog + serialize を、純 cljc の
;; 単一ソースに切り出したもの（ADR-2607020100）。node の text/tone/fukidashi は
;; kami.mangaka.expression の語彙（bubble/tone/weight/register）を共有し、genko doc ⇄
;; storyboard(kami.mangaka.text panel) を橋渡しする。
;;
;; 純データ/純関数のみ — WebGPU 描画・DOM・B2/PDS I/O は host 側（TS/Svelte ランタイム
;; や langgraph host-fn）に残す。babashka-safe / JVM・cljs・WASM 可搬。
;; Sibling of kami-mangaka-{text,expression,page,scene}-clj。ADR-2606282100/101 / 2607012100。
{:paths ["src"]

 :deps {org.clojure/clojure   {:mvn/version "1.12.0"}
        org.clojure/data.json {:mvn/version "2.5.0"}   ; clj: genko JSON doc の read/write
        io.github.kotoba-lang/kami-mangaka-expression {:local/root "../kami-mangaka-expression-clj"}}

 :aliases
 {:test {:extra-paths ["test"]
         :extra-deps  {io.github.cognitect-labs/test-runner
                       {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts   ["-m" "cognitect.test-runner"]}}}
