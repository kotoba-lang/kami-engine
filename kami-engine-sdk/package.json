{
  "name": "@etzhayyim/kami-engine-sdk",
  "version": "0.1.0",
  "description": "KAMI Engine SDK: Svelte 5 VRM character components, headless builders, Genko manga editor, trackpad embeds, and manufacturing planning helpers.",
  "type": "module",
  "license": "Apache-2.0",
  "homepage": "https://github.com/etzhayyim/kami-engine-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/etzhayyim/kami-engine-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/etzhayyim/kami-engine-sdk/issues"
  },
  "keywords": [
    "kami",
    "svelte",
    "vrm",
    "wgpu",
    "manga",
    "genko",
    "manufacturing",
    "gsplat"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./builders": {
      "types": "./dist/builders/index.d.ts",
      "svelte": "./dist/builders/index.js",
      "default": "./dist/builders/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    },
    "./data": {
      "types": "./dist/data/index.d.ts",
      "default": "./dist/data/index.js"
    },
    "./genko": {
      "types": "./dist/genko/index.d.ts",
      "svelte": "./dist/genko/index.js",
      "default": "./dist/genko/index.js"
    },
    "./genko/stores": {
      "types": "./dist/genko/stores/doc.svelte.d.ts",
      "svelte": "./dist/genko/stores/doc.svelte.js",
      "default": "./dist/genko/stores/doc.svelte.js"
    },
    "./genko/components": {
      "types": "./dist/genko/components/index.d.ts",
      "svelte": "./dist/genko/components/NodeTree.svelte",
      "default": "./dist/genko/components/NodeTree.svelte"
    },
    "./trackpad": {
      "types": "./dist/trackpad/index.d.ts",
      "default": "./dist/trackpad/index.js"
    },
    "./document": {
      "types": "./dist/document/index.d.ts",
      "default": "./dist/document/index.js"
    },
    "./manufacturing": {
      "types": "./dist/manufacturing/index.d.ts",
      "default": "./dist/manufacturing/index.js"
    },
    "./gsplat": {
      "types": "./dist/gsplat/index.d.ts",
      "default": "./dist/gsplat/index.js"
    },
    "./webvr": {
      "types": "./dist/webvr/index.d.ts",
      "svelte": "./dist/webvr/index.js",
      "default": "./dist/webvr/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "svelte-package -i src/lib",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "svelte": "^5.0.0",
    "@langchain/langgraph": ">=1.0.0",
    "@langchain/core": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@langchain/langgraph": { "optional": true },
    "@langchain/core": { "optional": true }
  },
  "devDependencies": {
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "@testing-library/svelte": "^5.3.1",
    "jsdom": "^29.0.2",
    "svelte": "^5.55.3",
    "svelte-check": "^4.4.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
