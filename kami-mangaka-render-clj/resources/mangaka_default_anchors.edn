;; mangaka render — work-AGNOSTIC default anchors (ADR-2606282100).
;;
;; The generic half of an anchor bible: the diffusion model, universal quality
;; tags, the CLIP-77 word budget, the universal manga negative set, and the
;; comic-standard layout→aspect map. A WORK supplies the rest in its own
;; render_anchors.edn (style-lead art direction + volume-color + characters +
;; environments) and `kami.mangaka.render/load-anchors` merges the work OVER
;; these defaults (work wins; :base-negative is the de-duped union).
{:model "cagliostrolab/animagine-xl-4.0"

 ;; Universal AnimagineXL quality tags (trail the prompt).
 :quality-tail ["masterpiece" "best quality" "very aesthetic" "absurdres"]

 ;; Token budget for the WHOLE positive prompt. We drive image-gen /generate
 ;; directly (own all 77 tokens); a conservative word cap stays under CLIP-77.
 :word-budget 42

 ;; Universal manga negatives — kept tight (≤ ~24 tags) so the whole negative
 ;; fits CLIP's 77-token window; most-important first. A work can ADD its own
 ;; :base-negative; the loader unions them.
 :base-negative
 ["lowres" "worst quality" "low quality" "bad anatomy" "bad hands"
  "extra digits" "blurry" "watermark" "signature" "text"
  "multiple panels" "tiled grid" "collage" "split screen" "speech bubble"
  "greyscale" "monochrome" "photorealistic" "3d render" "chibi"
  "wings" "deformed face" "nsfw"]

 ;; layout → aspect keyword (comic-standard; maps to dims in kami.mangaka.render).
 :aspect-by-layout
 {"splash" :2x3 "full-page" :2x3 "double-page spread" :16x9
  "2-panel-horizontal" :3x2 "2-panel-vertical" :3x4
  "3-panel-vertical" :3x4 "3-panel-horizontal" :16x9
  "4-panel-grid" :1x1 "insert" :1x1}}
