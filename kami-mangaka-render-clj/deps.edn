;; kami-mangaka-render-clj — work-agnostic 2D manga panel render commons.
;;
;; The Tier-1 "mangaka" platform layer (ADR-2606282100): prompt composition
;; (STYLE-FIRST, CLIP-77-budgeted) + the image-gen HTTP client + comic dims.
;; Work-specific semantics (which character, which environment, emotion→tags)
;; are INJECTED as :mappers — this crate hard-codes no story, character, or world.
;;
;; Sibling of kami-mangaka-scene (Rust/PyO3, 3D) and kami-mangaka-page-clj (komawari).
{:paths ["src" "resources"]

 :deps {org.clojure/clojure   {:mvn/version "1.12.0"}
        org.clojure/data.json {:mvn/version "2.5.0"}}

 :aliases
 {:test {:extra-paths ["test"]
         :extra-deps  {io.github.cognitect-labs/test-runner
                       {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts   ["-m" "cognitect.test-runner"]}}}
